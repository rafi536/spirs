<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ========================= -->
    <!-- INTERNET -->
    <!-- ========================= -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- ========================= -->
    <!-- CAMERA -->
    <!-- ========================= -->
    <uses-permission android:name="android.permission.CAMERA"/>

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false"/>

    <!-- ========================= -->
    <!-- LOCATION -->
    <!-- ========================= -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>

    <!-- ========================= -->
    <!-- STORAGE -->
    <!-- ========================= -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>

    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SPIRS"

        android:usesCleartextTraffic="true">

        <!-- ========================= -->
        <!-- FILE PROVIDER -->
        <!-- ========================= -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">

            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"/>
        </provider>

        <!-- ========================= -->
        <!-- SPLASH SCREEN -->
        <!-- ========================= -->
        <activity
            android:name=".SplashActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>

                <category
                    android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- ========================= -->
        <!-- AUTH -->
        <!-- ========================= -->
        <activity
            android:name=".LoginRegisterActivity"
            android:exported="false"/>

        <activity
            android:name=".LoginActivity"
            android:exported="false"/>

        <activity
            android:name=".RegisterActivity"
            android:exported="false"/>

        <activity
            android:name=".LoginAdminActivity"
            android:exported="false"/>

        <!-- ========================= -->
        <!-- USER -->
        <!-- ========================= -->
        <activity
            android:name=".BerandaActivity"
            android:exported="false"/>

        <activity
            android:name=".ProfileActivity"
            android:exported="false"/>

        <!-- ========================= -->
        <!-- LAPORAN -->
        <!-- ========================= -->
        <activity
            android:name=".InputDeskripsiActivity"
            android:exported="false"/>

        <activity
            android:name=".UploadFotoActivity"
            android:exported="false"/>

        <activity
            android:name=".LokasiActivity"
            android:exported="false"/>

        <activity
            android:name=".SubmitLaporanActivity"
            android:exported="false"/>

        <activity
            android:name=".LoadingSubmitActivity"
            android:exported="false"/>

        <activity
            android:name=".SuccessSubmitActivity"
            android:exported="false"/>

        <!-- ========================= -->
        <!-- DAFTAR & DETAIL -->
        <!-- ========================= -->
        <activity
            android:name=".DaftarLaporanActivity"
            android:exported="false"/>

        <activity
            android:name=".DetailLaporanActivity"
            android:exported="false"/>

        <!-- ========================= -->
        <!-- ADMIN -->
        <!-- ========================= -->
        <activity
            android:name=".BerandaAdminActivity"
            android:exported="false"/>

        <activity
            android:name=".UpdateStatusLaporanActivity"
            android:exported="false"/>

        <activity
            android:name=".ValidasiInputActivity"
            android:exported="false"/>

        <activity
            android:name=".ViewImageActivity"
            android:exported="false"/>

    </application>

</manifest>