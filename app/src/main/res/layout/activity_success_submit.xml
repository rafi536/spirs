<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1F3C88">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="24dp"
        android:layout_centerInParent="true"
        app:cardCornerRadius="35dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Lingkaran Icon -->
            <ImageView
                android:id="@+id/imgSuccess"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/check_circle"
                android:contentDescription="Success" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LAPORAN TERKIRIM"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#000000"
                android:layout_marginTop="24dp" />

            <TextView
                android:id="@+id/tvIdLaporan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID LAPORAN : -"
                android:textSize="16sp"
                android:textColor="#444444"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnBeranda"
                android:layout_width="220dp"
                android:layout_height="55dp"
                android:layout_marginTop="40dp"
                android:text="KEMBALI KE BERANDA"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2962FF"
                app:cornerRadius="15dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</RelativeLayout>