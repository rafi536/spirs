<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- BACK BUTTON -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:scaleType="centerInside"
        android:src="@drawable/navigation"
        android:contentDescription="Back Button" />

    <!-- CARD -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/btnBack"
        android:layout_marginTop="80dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- TITLE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="DETAIL LAPORAN"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- JUDUL -->
                <EditText
                    android:id="@+id/etJudul"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:background="@android:drawable/editbox_background"
                    android:enabled="false"
                    android:padding="10dp"
                    android:textColor="#000000"
                    android:hint="Judul Laporan" />

                <!-- LOKASI -->
                <EditText
                    android:id="@+id/etLokasi"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@android:drawable/editbox_background"
                    android:enabled="false"
                    android:padding="10dp"
                    android:textColor="#000000"
                    android:hint="Lokasi" />

                <!-- DESKRIPSI -->
                <EditText
                    android:id="@+id/etDeskripsi"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="10dp"
                    android:background="@android:drawable/editbox_background"
                    android:enabled="false"
                    android:gravity="top"
                    android:padding="10dp"
                    android:textColor="#000000"
                    android:inputType="textMultiLine"
                    android:hint="Deskripsi" />

                <!-- KOORDINAT -->
                <EditText
                    android:id="@+id/etKoordinat"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@android:drawable/editbox_background"
                    android:enabled="false"
                    android:padding="10dp"
                    android:textColor="#000000"
                    android:hint="Koordinat" />

                <!-- STATUS -->
                <EditText
                    android:id="@+id/etStatus"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@android:drawable/editbox_background"
                    android:enabled="false"
                    android:padding="10dp"
                    android:textColor="#000000"
                    android:hint="Status Laporan" />

                <!-- BUTTON LIHAT FOTO -->
                <Button
                    android:id="@+id/btnLihatFoto"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:text="Lihat Foto"
                    android:backgroundTint="#2962FF"
                    android:textColor="#FFFFFF" />

                <!-- BUTTON EDIT -->
                <Button
                    android:id="@+id/btnEdit"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:text="Edit Status"
                    android:backgroundTint="#FF9800"
                    android:textColor="#FFFFFF"
                    android:visibility="gone" />

            </LinearLayout>

        </ScrollView>

    </androidx.cardview.widget.CardView>

</RelativeLayout>