<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1F3C88">

    <!-- CARD UTAMA -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardValidasi"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#F0F0F0">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp">

            <!-- CONTENT -->
            <ScrollView
                android:id="@+id/scrollContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_above="@id/btnSimpan"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- HEADER -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <ImageButton
                            android:id="@+id/btnBack"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginTop="8dp"
                            android:src="@drawable/navigation"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Back"
                            android:scaleType="fitCenter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SISTEM VALIDASI INPUT"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#212121"
                            android:layout_centerInParent="true" />
                    </RelativeLayout>

                    <!-- FORM CARD -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MASUKAN DATA"
                                android:textStyle="bold"
                                android:textColor="#212121"
                                android:layout_marginBottom="16dp" />

                            <!-- NAMA -->
                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginBottom="10dp">

                                <TextView
                                    android:id="@+id/tvNamaLaporan"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="Nama Laporan : ..."
                                    android:background="@drawable/input_bg"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="48dp"
                                    android:gravity="center_vertical"
                                    android:textColor="#424242" />
                            </RelativeLayout>

                            <!-- ID LAPORAN -->
                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginBottom="10dp">

                                <TextView
                                    android:id="@+id/tvIdLaporan"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="ID Laporan : ..."
                                    android:background="@drawable/input_bg"
                                    android:paddingStart="12dp"
                                    android:gravity="center_vertical"
                                    android:textColor="#424242" />
                            </RelativeLayout>

                            <!-- TANGGAL -->
                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginBottom="10dp">

                                <TextView
                                    android:id="@+id/tvTanggal"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="Tanggal : ..."
                                    android:background="@drawable/input_bg"
                                    android:paddingStart="12dp"
                                    android:gravity="center_vertical"
                                    android:textColor="#424242" />
                            </RelativeLayout>

                            <!-- STATUS VALIDASI (FIX ERROR) -->
                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginBottom="10dp">

                                <TextView
                                    android:id="@+id/tvStatusValidasi"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="Status Baru : ..."
                                    android:background="@drawable/input_bg"
                                    android:paddingStart="12dp"
                                    android:gravity="center_vertical"
                                    android:textColor="#424242" />
                            </RelativeLayout>

                            <!-- ID HASIL (FIX ERROR) -->
                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginBottom="10dp">

                                <TextView
                                    android:id="@+id/tvIdHasil"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="ID Hasil : ..."
                                    android:background="@drawable/input_bg"
                                    android:paddingStart="12dp"
                                    android:gravity="center_vertical"
                                    android:textColor="#424242" />
                            </RelativeLayout>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </ScrollView>

            <!-- BUTTON SIMPAN -->
            <Button
                android:id="@+id/btnSimpan"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_alignParentBottom="true"
                android:text="SIMPAN"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1E6FE8" />

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

</RelativeLayout>